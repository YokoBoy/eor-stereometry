{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    },
    {
      "src": "**/*.{html,css,js,png,jpg,jpeg,gif,svg,ico,json,xml}",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "server.js"
    },
    {
      "src": "/favicon.ico",
      "dest": "/favicon.ico"
    },
    {
      "src": "/src/media/img/(.*)",
      "dest": "/src/media/img/$1"
    },
    {
      "src": "/(index|login|profile|videos|assignments|watch|admin|about)\\.html",
      "dest": "/$1.html"
    },
    {
      "src": "/(.*)\\.(js|css|png|jpg|jpeg|gif|svg|json|xml|ico)",
      "dest": "/$1.$2"
    },
    {
      "src": "/",
      "dest": "/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "server.js"
    }
  ]
}
