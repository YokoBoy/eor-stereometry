{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(api|static|src)/(.*)",
      "dest": "server.js"
    },
    {
      "src": "/(.*)\\.(html|js|css|png|jpg|jpeg|gif|svg|ico|json|xml)",
      "dest": "/$1.$2"
    },
    {
      "src": "/",
      "dest": "index.html"
    },
    {
      "src": "/(.*)",
      "dest": "server.js"
    }
  ]
}
