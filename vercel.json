{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    },
    {
      "src": "*.html",
      "use": "@vercel/static"
    },
    {
      "src": "*.css",
      "use": "@vercel/static"
    },
    {
      "src": "*.js",
      "use": "@vercel/static"
    },
    {
      "src": "*.png",
      "use": "@vercel/static"
    },
    {
      "src": "manifest.json",
      "use": "@vercel/static"
    },
    {
      "src": "*.ico",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "server.js"
    },
    {
      "src": "/favicon.ico",
      "dest": "/favicon.ico"
    },
    {
      "src": "/(index|login|profile|videos|assignments|watch|admin|about)\\.html",
      "dest": "/$1.html"
    },
    {
      "src": "/(.*)\\.(js|css|png|jpg|jpeg|gif|svg|json|xml)",
      "dest": "/$1.$2"
    },
    {
      "src": "/",
      "dest": "/index.html"
    }
  ]
}
